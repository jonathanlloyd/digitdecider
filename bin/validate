#!/usr/bin/env python

import digitdecider
from digitdecider import ModelParams

NUM_EPOCHS = 10


def main():
    with open("./weights/digitdecider.safetensors", "rb") as f:
        serialized_model = f.read()

    test_data_loader = digitdecider.make_test_data_loader()
    model_params = ModelParams.from_safetensors_no_grad(serialized_model)
    accuracy = digitdecider.evaluate_model(test_data_loader, model_params)

    print(f"Loaded model accuracy: {accuracy}")


if __name__ == "__main__":
    main()
