#!/usr/bin/env python

import digitdecider

NUM_EPOCHS = 10


def main():
    training_data_loader = digitdecider.make_training_data_loader()
    test_data_loader = digitdecider.make_test_data_loader()

    model_params = digitdecider.init_model_parameters()

    for epoch in range(0, NUM_EPOCHS):
        epoch_loss = digitdecider.run_epoch(training_data_loader, model_params)
        epoch_accuracy = digitdecider.evaluate_model(test_data_loader, model_params)
        print(f"Epoch {epoch}: loss={epoch_loss}, accuracy={epoch_accuracy}")

    serialized_model = model_params.to_safetensors()

    with open("./weights/digitdecider.safetensors", "wb") as f:
        f.write(serialized_model)


if __name__ == "__main__":
    main()
